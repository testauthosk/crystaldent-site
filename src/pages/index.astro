---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import TriPanels from "../components/TriPanels.astro";
import Services from "../components/Services.astro";
import Bleed from "../components/Bleed.astro";
import Trust from "../components/Trust.astro";
import Doctors from "../components/Doctors.astro";
import Booking from "../components/Booking.astro";
import Faq from "../components/Faq.astro";
import Footer from "../components/Footer.astro";
import FloatingActions from "../components/FloatingActions.astro";
import ChatPanel from "../components/ChatPanel.astro";
import CalendarModal from "../components/CalendarModal.astro";
---

<Layout
  title="CrystalDent — Viena Dental Clinic"
  description="Комплексные решения для идеальной улыбки: имплантация, элайнеры, протезирование и профилактика. Онлайн-запись к врачу."
>
  <Nav />

  <!--
    На мобильных body зафиксирован, а страница скроллится внутри #scrollRoot.
    Тогда мобильный браузер не сворачивает адресную строку, вьюпорт не меняет
    высоту — и сайт не дёргается при скролле вверх.
    Фиксированные слои (шапка, прелоадер, кнопки, чат) живут снаружи.
  -->
  <div id="scrollRoot">
    <div id="scrollContent">
      <main>
        <Hero />
        <TriPanels />
        <Services />
        <Bleed />
        <Trust />
        <Doctors />
        <Booking />
        <Faq />
      </main>
      <Footer />
    </div>
  </div>

  <FloatingActions />
  <ChatPanel />
  <CalendarModal />
</Layout>
