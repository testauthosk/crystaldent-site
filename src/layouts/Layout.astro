---
import "../styles/global.css";
import Preloader from "../components/Preloader.astro";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="ru" class="grain">
  <head>
    <meta charset="utf-8" />
    <!-- viewport обязательна: без неё телефон рендерит десктоп-ширину -->
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0c1a22" />
    <link rel="icon" href="/brand/mark.svg" type="image/svg+xml" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="ru_RU" />

    <!-- ставим .js до первой отрисовки, чтобы reveal-элементы не мигнули -->
    <script is:inline>
      document.documentElement.classList.add("js");
    </script>
  </head>

  <body>
    <Preloader />

    <a href="#main" class="skip">К содержимому</a>

    <slot />

    <script>
      import "../scripts/motion.ts";
    </script>

    <style>
      .skip {
        position: absolute;
        left: -9999px;
        top: 0;
        z-index: 200;
        background: var(--color-accent);
        color: var(--color-accent-ink);
        padding: 0.75rem 1.25rem;
        font-size: var(--text-xs);
        text-transform: uppercase;
        letter-spacing: 0.1em;
      }
      .skip:focus {
        left: 1rem;
        top: 1rem;
      }
    </style>
  </body>
</html>
