---
import { panels } from "../data/site";

/**
 * Три панели-кадра. Раньше по бокам стояли предметные модели, вырезанные на
 * чёрном, — читались как непонятные объекты. Теперь везде фотография действия:
 * элайнер в руках, врач, работа над протезом.
 */
const arrow = `<svg viewBox="0 0 16 16" fill="none"><path d="M4 12L12 4M12 4H6M12 4V10" stroke="currentColor" stroke-width="1.4"/></svg>`;
---

<section class="tri">
  <!-- левая: элайнеры -->
  <article class="panel group reveal">
    <div class="panel-photo">
      <img
        src={panels.left.photo}
        alt="Прозрачный элайнер"
        width="860"
        height="1160"
        loading="lazy"
        decoding="async"
        data-parallax="5"
      />
      <span class="veil veil--top" aria-hidden="true"></span>
    </div>

    <a href={panels.left.href} class="panel-head">
      <h2 class="panel-title">
        {panels.left.title.map((l) => <span>{l}</span>)}
      </h2>
      <span class="arrow-box" set:html={arrow} />
    </a>
    <p class="panel-text">{panels.left.text}</p>
  </article>

  <!-- центр: врач -->
  <article class="panel panel--center reveal">
    <div class="panel-photo">
      <img
        src={panels.center.photo}
        alt="Врач стоматологической клиники CrystalDent"
        width="860"
        height="1160"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        data-parallax="5"
      />
      <span class="veil veil--bottom" aria-hidden="true"></span>
    </div>

    <div class="panel-overlay">
      <h2 class="panel-title panel-title--lg">
        {panels.center.title.map((l) => <span>{l}</span>)}
      </h2>
      <a href={panels.center.href} class="btn btn--paper">
        <span class="btn__label">{panels.center.cta}</span>
      </a>
    </div>
  </article>

  <!-- правая: протезирование -->
  <article class="panel group reveal">
    <div class="panel-photo">
      <img
        src={panels.right.photo}
        alt="Работа зубного техника над протезом"
        width="860"
        height="1160"
        loading="lazy"
        decoding="async"
        data-parallax="5"
      />
      <span class="veil veil--top" aria-hidden="true"></span>
    </div>

    <a href={panels.right.href} class="panel-head">
      <h2 class="panel-title">
        {panels.right.title.map((l) => <span>{l}</span>)}
      </h2>
      <span class="arrow-box" set:html={arrow} />
    </a>
    <p class="panel-text">{panels.right.text}</p>
  </article>
</section>

<style>
  .tri {
    display: grid;
    /* minmax(0,1fr): иначе min-content длинных слов («ПРОТЕЗИРОВАНИЕ»)
       раздвигает трек и рождает горизонтальный скролл на узких экранах */
    grid-template-columns: minmax(0, 1fr);
    gap: 1px;
    background: var(--color-line-soft);
    border-bottom: 1px solid var(--color-line-soft);
  }

  .panel {
    position: relative;
    isolation: isolate;
    min-width: 0;
    overflow: clip;
    background: var(--color-ink-900);
    padding: clamp(1.5rem, 2.6vw, 2.25rem);
    display: flex;
    flex-direction: column;
    min-height: 460px;
  }

  /* фото занимает панель целиком, текст лежит поверх затемнения */
  .panel-photo {
    position: absolute;
    inset: -6% 0;
    z-index: -1;
  }
  .panel-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    will-change: transform;
    transition: transform 900ms var(--ease-out-expo);
  }
  .panel.group:hover .panel-photo img {
    transform: scale(1.03);
  }

  .veil {
    position: absolute;
    inset: 0;
  }
  .veil--top {
    background: linear-gradient(
      to bottom,
      color-mix(in oklch, var(--color-ink-950) 88%, transparent) 0%,
      color-mix(in oklch, var(--color-ink-950) 55%, transparent) 38%,
      color-mix(in oklch, var(--color-ink-950) 22%, transparent) 100%
    );
  }
  .veil--bottom {
    background: linear-gradient(
      to top,
      color-mix(in oklch, var(--color-ink-950) 90%, transparent) 4%,
      color-mix(in oklch, var(--color-ink-950) 40%, transparent) 46%,
      color-mix(in oklch, var(--color-ink-950) 12%, transparent) 100%
    );
  }

  .panel-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1.5rem;
    color: var(--color-fg);
  }

  .panel-title {
    font-family: var(--font-display);
    font-weight: 700;
    text-transform: uppercase;
    font-size: clamp(1.05rem, 1.35vw, 1.32rem);
    line-height: 1.14;
    letter-spacing: 0.02em;
    margin: 0;
  }
  .panel-title span {
    display: block;
    overflow-wrap: anywhere;
  }
  .panel-title--lg {
    font-size: clamp(1.25rem, 1.9vw, 1.75rem);
  }

  .panel-text {
    margin: 0.9rem 0 0;
    font-size: var(--text-sm);
    color: var(--color-fg-dim);
    max-width: 30ch;
  }

  /* ── центр ── */
  .panel--center {
    padding: 0;
    min-height: 520px;
  }
  .panel-overlay {
    position: relative;
    margin-top: auto;
    padding: clamp(1.5rem, 2.6vw, 2.25rem);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.25rem;
  }

  @media (min-width: 900px) {
    .tri {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.08fr) minmax(0, 1fr);
    }
    .panel,
    .panel--center {
      min-height: 620px;
    }
  }
</style>
