---
import { services } from "../data/site";

/** Асимметричные ширины: ячейки разного веса, а не 3 одинаковые карточки. */
const cols = [7, 5, 4, 4, 4, 8];
---

<section class="sec" id="services">
  <div class="wrap">
    <header class="sec-head reveal">
      <span class="eyebrow">Услуги</span>
      <h2 class="display sec-title">
        Что мы<br />делаем
      </h2>
      <p class="lede">
        Полный цикл — от диагностики до контрольного осмотра. Каждый план лечения врач согласовывает
        с пациентом до начала работы.
      </p>
    </header>

    <div class="bento">
      {
        services.map((s, i) => (
          <article class="card group reveal" style={`--cols:${cols[i]}`}>
            <span class="card-n tnum">{s.n}</span>
            <div class="card-body">
              <h3 class="card-title">{s.title}</h3>
              <p class="card-text">{s.text}</p>
            </div>
            <span class="arrow-box">
              <svg viewBox="0 0 16 16" fill="none">
                <path d="M4 12L12 4M12 4H6M12 4V10" stroke="currentColor" stroke-width="1.4" />
              </svg>
            </span>
          </article>
        ))
      }

      <article class="card card--cta group reveal" style="--cols:4">
        <div class="card-body">
          <h3 class="card-title">Не нашли нужное?</h3>
          <p class="card-text">Опишите задачу — врач подберёт план на консультации.</p>
        </div>
        <a href="#booking" class="card-link">
          Записаться
          <svg viewBox="0 0 16 16" fill="none">
            <path d="M4 12L12 4M12 4H6M12 4V10" stroke="currentColor" stroke-width="1.4"></path>
          </svg>
        </a>
      </article>
    </div>
  </div>
</section>

<style>
  .sec {
    padding: clamp(4rem, 9vw, 8.5rem) 0;
    position: relative;
  }
  .wrap {
    max-width: 1600px;
    margin: 0 auto;
    padding: 0 clamp(1rem, 3vw, 2.5rem);
  }

  .sec-head {
    display: grid;
    gap: 1.25rem;
    margin-bottom: clamp(2.5rem, 4vw, 4rem);
  }
  .sec-title {
    font-size: clamp(1.9rem, 4.4vw, 4rem);
    margin: 0;
  }

  .bento {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    background: var(--color-line-soft);
    border: 1px solid var(--color-line-soft);
  }

  .card {
    position: relative;
    background: var(--color-ink-900);
    padding: clamp(1.4rem, 2.2vw, 2rem);
    min-height: 220px;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    transition: background 220ms var(--ease-out-expo);
  }
  .card:hover {
    background: var(--color-ink-850);
  }

  .card-n {
    font-family: var(--font-display);
    font-size: var(--text-2xs);
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--color-fg-faint);
  }

  .card-body {
    margin-top: auto;
  }
  .card-title {
    font-family: var(--font-display);
    font-weight: 700;
    text-transform: uppercase;
    font-size: clamp(1rem, 1.25vw, 1.22rem);
    line-height: 1.16;
    letter-spacing: 0.02em;
    margin: 0 0 0.6rem;
  }
  .card-text {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--color-fg-dim);
    max-width: 40ch;
  }

  .card .arrow-box {
    position: absolute;
    top: clamp(1.4rem, 2.2vw, 2rem);
    right: clamp(1.4rem, 2.2vw, 2rem);
  }

  .card--cta {
    background: var(--color-ink-850);
    justify-content: space-between;
  }
  .card--cta .card-body {
    margin-top: 0;
  }
  .card-link {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    margin-top: auto;
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
  }
  .card-link svg {
    width: 14px;
    height: 14px;
    transition: transform 220ms var(--ease-out-expo);
  }
  .card--cta:hover .card-link svg {
    transform: translate(2px, -2px);
  }

  @media (min-width: 720px) {
    .bento {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1080px) {
    .bento {
      grid-template-columns: repeat(12, 1fr);
    }
    .card {
      grid-column: span var(--cols);
    }
    .card:first-child {
      min-height: 300px;
    }
  }
</style>
