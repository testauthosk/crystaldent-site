---
import { services } from "../data/site";
---

<section class="sec" id="services">
  <div class="wrap">
    <header class="head">
      <div>
        <span class="eyebrow reveal">Услуги</span>
        <h2 class="display sec-title" data-split>Что мы делаем</h2>
      </div>
      <p class="lede reveal">
        Полный цикл — от диагностики до контрольного осмотра. План лечения врач согласовывает
        с пациентом до начала работы.
      </p>
    </header>

    <!-- Редакторский список, а не сетка одинаковых карточек:
         превью услуги следует за курсором. -->
    <ul class="list" id="srvList">
      {
        services.map((s) => (
          <li class="row">
            <a href="#booking" class="row-link" data-srv={s.photo}>
              <span class="row-n tnum">{s.n}</span>
              <span class="row-title">{s.title}</span>
              <span class="row-text">{s.text}</span>
              <span class="row-arrow" aria-hidden="true">
                <svg viewBox="0 0 16 16" fill="none">
                  <path d="M4 12L12 4M12 4H6M12 4V10" stroke="currentColor" stroke-width="1.4" />
                </svg>
              </span>
              <img class="row-thumb" src={s.photo} alt="" width="760" height="570" loading="lazy" decoding="async" />
            </a>
          </li>
        ))
      }
    </ul>
  </div>

  <!-- превью на десктопе -->
  <div class="preview" id="srvPreview" aria-hidden="true">
    {
      services.map((s) => (
        <img src={s.photo} alt="" data-preview={s.photo} width="760" height="570" loading="lazy" decoding="async" />
      ))
    }
  </div>
</section>

<style>
  .sec {
    position: relative;
    padding: var(--sec-y) 0;
  }
  .wrap {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: 0 var(--gutter);
  }

  .head {
    display: grid;
    gap: 1.75rem;
    margin-bottom: clamp(3rem, 6vw, 6rem);
  }
  .head .eyebrow {
    margin-bottom: 1.5rem;
  }

  .list {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--color-line-soft);
  }
  .row {
    border-bottom: 1px solid var(--color-line-soft);
  }

  .row-link {
    position: relative;
    display: grid;
    grid-template-columns: auto 1fr auto;
    grid-template-areas:
      "n title arrow"
      ". text text";
    align-items: center;
    gap: 0.5rem 1.5rem;
    padding: clamp(1.5rem, 2.6vw, 2.4rem) 0;
    color: var(--color-fg);
    transition: color 200ms var(--ease-out-expo);
  }
  /* заливка строки при наведении — тянется слева, а не мигает */
  .row-link::before {
    content: "";
    position: absolute;
    inset: 0 calc(var(--gutter) * -0.5);
    background: var(--color-ink-850);
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 420ms var(--ease-out-expo);
    z-index: -1;
  }
  .row-link:hover::before {
    transform: scaleX(1);
  }

  .row-n {
    grid-area: n;
    font-family: var(--font-display);
    font-size: var(--text-2xs);
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--color-fg-faint);
    width: 3ch;
  }

  .row-title {
    grid-area: title;
    font-family: var(--font-display);
    font-weight: 700;
    text-transform: uppercase;
    font-size: clamp(1.25rem, 2.6vw, 2.5rem);
    line-height: 1;
    letter-spacing: -0.006em;
    transition: transform 420ms var(--ease-out-expo);
  }
  .row-link:hover .row-title {
    transform: translateX(clamp(8px, 1.2vw, 22px));
  }

  .row-text {
    grid-area: text;
    font-size: var(--text-sm);
    color: var(--color-fg-faint);
    max-width: 52ch;
    transition: color 200ms var(--ease-out-expo);
  }
  .row-link:hover .row-text {
    color: var(--color-fg-dim);
  }

  .row-arrow {
    grid-area: arrow;
    display: grid;
    place-items: center;
    width: 42px;
    height: 42px;
    border: 1px solid var(--color-line);
    color: var(--color-fg-dim);
    transition:
      background 220ms var(--ease-out-expo),
      color 220ms var(--ease-out-expo),
      border-color 220ms var(--ease-out-expo);
  }
  .row-arrow svg {
    width: 15px;
    height: 15px;
    transition: transform 300ms var(--ease-out-expo);
  }
  .row-link:hover .row-arrow {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: var(--color-accent-ink);
  }
  .row-link:hover .row-arrow svg {
    transform: translate(2px, -2px);
  }

  /* миниатюра в строке — только на узких экранах, где курсора нет */
  .row-thumb {
    grid-area: text;
    justify-self: end;
    width: 76px;
    height: 58px;
    object-fit: cover;
    display: none;
  }

  /* ── превью, летящее за курсором ── */
  .preview {
    position: fixed;
    top: 0;
    left: 0;
    width: clamp(260px, 22vw, 380px);
    aspect-ratio: 4 / 3;
    pointer-events: none;
    z-index: 40;
    opacity: 0;
    display: none;
    will-change: transform;
  }
  .preview img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
  }

  @media (min-width: 900px) {
    .head {
      grid-template-columns: 1.35fr 0.65fr;
      align-items: end;
      gap: 4rem;
    }
    .row-link {
      grid-template-columns: auto minmax(0, 1.1fr) minmax(0, 1fr) auto;
      grid-template-areas: "n title text arrow";
      gap: 2rem;
    }
    .row-text {
      max-width: 44ch;
    }
    /* показываем превью только там, где есть мышь */
    .preview {
      display: block;
    }
  }

  @media (max-width: 899px) {
    .row-thumb {
      display: block;
    }
    .row-text {
      max-width: 32ch;
    }
  }

  @media (hover: none) {
    .preview {
      display: none;
    }
  }
</style>
