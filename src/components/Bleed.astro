---
/** Широкий кадр во всю ширину: сбивает монотонный ритм «заголовок → сетка». */
---

<section class="bleed">
  <div class="frame" data-img-reveal>
    <img
      src="/img/bleed.webp"
      alt="Приём в стоматологической клинике CrystalDent"
      width="2200"
      height="1050"
      loading="lazy"
      decoding="async"
      data-parallax="10"
    />
    <span class="veil" aria-hidden="true"></span>
  </div>

  <div class="over">
    <div class="wrap">
      <p class="quote display" data-split>Лечение начинается с диагноза, а не с прайса</p>
      <p class="note reveal">
        Врач показывает снимок, объясняет, что происходит с зубом, и предлагает варианты — вместе
        с их сроками и стоимостью. Решение всегда за пациентом.
      </p>
    </div>
  </div>
</section>

<style>
  .bleed {
    position: relative;
    isolation: isolate;
    min-height: clamp(420px, 62vh, 760px);
    display: grid;
    align-items: end;
    border-block: 1px solid var(--color-line-soft);
    overflow: hidden;
  }

  .frame {
    position: absolute;
    inset: -8% 0;
    z-index: -1;
  }
  .frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 50% 42%;
  }
  .veil {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      var(--color-ink-950) 4%,
      color-mix(in oklch, var(--color-ink-950) 55%, transparent) 46%,
      color-mix(in oklch, var(--color-ink-950) 20%, transparent)
    );
  }

  .over {
    padding: clamp(2.5rem, 6vw, 6rem) 0;
  }
  .wrap {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: 0 var(--gutter);
    display: grid;
    gap: 1.75rem;
  }

  .quote {
    font-size: clamp(1.6rem, 3.6vw, 3.4rem);
    max-width: 18ch;
    margin: 0;
  }
  .note {
    font-size: var(--text-sm);
    line-height: 1.6;
    color: var(--color-fg-dim);
    max-width: 52ch;
    margin: 0;
  }

  @media (min-width: 1000px) {
    .wrap {
      grid-template-columns: 1.15fr 0.85fr;
      align-items: end;
      gap: 4rem;
    }
  }
</style>
