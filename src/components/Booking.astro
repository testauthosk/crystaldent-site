---
import { slots, bookingSteps, services } from "../data/site";
---

<section class="sec" id="booking">
  <div class="aura" aria-hidden="true"></div>

  <div class="wrap">
    <div class="grid">
      <header class="b-head">
        <span class="eyebrow reveal">Онлайн-запись</span>
        <h2 class="display sec-title b-title" data-split>Два клика до приёма</h2>
        <p class="lede reveal">
          Выберите услугу, удобный день и время. Администратор подтвердит визит и напомнит о нём
          заранее.
        </p>

        <ol class="steps reveal">
          {
            bookingSteps.map((s) => (
              <li>
                <span class="step-n tnum">{s.n}</span>
                <span class="step-l">{s.label}</span>
              </li>
            ))
          }
        </ol>
      </header>

      <div class="panel reveal">
        <!-- 01 услуга: свой дропдаун, а не системный select -->
        <div class="field">
          <span class="f-label" id="srvLabel">Услуга</span>
          <div class="sel" id="srvSelect">
            <button
              type="button"
              class="sel-btn"
              id="srvBtn"
              aria-haspopup="listbox"
              aria-expanded="false"
              aria-labelledby="srvLabel srvValue"
            >
              <span id="srvValue">{services[0].title}</span>
              <span class="sel-chev" aria-hidden="true">
                <svg viewBox="0 0 16 16" fill="none">
                  <path d="M3 6L8 11L13 6" stroke="currentColor" stroke-width="1.4" />
                </svg>
              </span>
            </button>

            <ul class="sel-list" id="srvList2" role="listbox" tabindex="-1" aria-labelledby="srvLabel">
              {
                services.map((s, i) => (
                  <li role="option" aria-selected={i === 0 ? "true" : "false"} data-value={s.title}>
                    <span class="sel-n tnum">{s.n}</span>
                    <span>{s.title}</span>
                  </li>
                ))
              }
              <li role="option" aria-selected="false" data-value="Первичная консультация">
                <span class="sel-n tnum">07</span>
                <span>Первичная консультация</span>
              </li>
            </ul>
          </div>
        </div>

        <!-- 02 дата -->
        <div class="field">
          <div class="cal-head">
            <span class="f-label">Дата</span>
            <div class="cal-nav">
              <span class="cal-month tnum" id="calMonth"></span>
              <button type="button" id="calPrev" aria-label="Предыдущие дни">
                <svg viewBox="0 0 16 16" fill="none"><path d="M10 3L5 8l5 5" stroke="currentColor" stroke-width="1.4"/></svg>
              </button>
              <button type="button" id="calNext" aria-label="Следующие дни">
                <svg viewBox="0 0 16 16" fill="none"><path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="1.4"/></svg>
              </button>
            </div>
          </div>

          <div class="day-strip no-bar" id="dayStrip">
            <div class="day-track" id="dayTrack">
              <!-- подложка выделения: плавает между числами, а не перескакивает -->
              <span class="day-ind" id="dayInd" aria-hidden="true"></span>
            </div>
          </div>
        </div>

        <!-- 03 время -->
        <div class="field">
          <span class="f-label">Время</span>
          <div id="slotWrap" class="slots">
            {
              slots.map((t) => (
                <button type="button" class="slot tnum" data-slot={t}>
                  {t}
                </button>
              ))
            }
          </div>
        </div>

        <div class="summary">
          <div>
            <span class="f-label">Ваш визит</span>
            <span id="bookingSummary" class="sum-value tnum" data-state="empty">
              Выберите дату и время
            </span>
          </div>
          <a href="#contacts" class="btn" data-magnetic>
            <span class="btn__label">Подтвердить</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .sec {
    position: relative;
    padding: var(--sec-y) 0;
    overflow: hidden;
  }
  .wrap {
    position: relative;
    z-index: 1;
    max-width: var(--maxw);
    margin: 0 auto;
    padding: 0 var(--gutter);
  }

  .grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: clamp(2.5rem, 4vw, 5rem);
    align-items: start;
  }

  .b-title {
    margin: 1.25rem 0 1.75rem;
  }

  .steps {
    list-style: none;
    margin: 2.5rem 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 1px;
    background: var(--color-line-soft);
    border: 1px solid var(--color-line-soft);
  }
  .steps li {
    flex: 1 1 120px;
    min-width: 0;
    background: var(--color-ink-900);
    padding: 1rem 1.15rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .step-n {
    font-family: var(--font-display);
    font-size: var(--text-2xs);
    font-weight: 700;
    color: var(--color-accent);
    letter-spacing: 0.1em;
  }
  .step-l {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-fg-dim);
  }

  .panel {
    background: var(--color-ink-850);
    border: 1px solid var(--color-line-soft);
    padding: clamp(1.25rem, 2.2vw, 2rem);
    display: grid;
    gap: 1.75rem;
    min-width: 0;
  }

  .field {
    display: grid;
    gap: 0.75rem;
    min-width: 0;
  }
  .f-label {
    font-size: var(--text-2xs);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-fg-faint);
  }

  /* ── свой дропдаун ── */
  .sel {
    position: relative;
  }
  .sel-btn {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    background: var(--color-ink-900);
    border: 1px solid var(--color-line);
    color: var(--color-fg);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    text-align: left;
    padding: 1rem 1.1rem;
    cursor: pointer;
    transition: border-color 180ms var(--ease-out-expo);
  }
  .sel-btn:hover,
  .sel-btn[aria-expanded="true"] {
    border-color: var(--color-fg-faint);
  }
  .sel-chev {
    display: grid;
    place-items: center;
    width: 16px;
    height: 16px;
    color: var(--color-fg-faint);
    flex: none;
  }
  .sel-chev svg {
    width: 100%;
    height: 100%;
    transition: transform 280ms var(--ease-out-expo);
  }
  .sel-btn[aria-expanded="true"] .sel-chev svg {
    transform: rotate(180deg);
  }

  .sel-list {
    position: absolute;
    top: calc(100% + 6px);
    left: 0;
    right: 0;
    z-index: 20;
    margin: 0;
    padding: 0;
    list-style: none;
    background: var(--color-ink-900);
    border: 1px solid var(--color-line);
    max-height: 288px;
    overflow-y: auto;
    clip-path: inset(0 0 100% 0);
    pointer-events: none;
  }
  .sel-list.is-open {
    pointer-events: auto;
  }
  .sel-list li {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    padding: 0.85rem 1.1rem;
    font-size: var(--text-sm);
    color: var(--color-fg-dim);
    cursor: pointer;
    border-bottom: 1px solid var(--color-line-soft);
    transition:
      background 160ms var(--ease-out-expo),
      color 160ms var(--ease-out-expo);
  }
  .sel-list li:last-child {
    border-bottom: 0;
  }
  .sel-list li:hover,
  .sel-list li.is-active {
    background: var(--color-ink-850);
    color: var(--color-fg);
  }
  .sel-list li[aria-selected="true"] .sel-n {
    color: var(--color-accent);
  }
  .sel-n {
    font-family: var(--font-display);
    font-size: var(--text-2xs);
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--color-fg-faint);
  }

  /* ── календарь ── */
  .cal-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .cal-nav {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .cal-month {
    font-size: var(--text-2xs);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-fg-dim);
    margin-right: 0.35rem;
  }
  .cal-nav button {
    display: grid;
    place-items: center;
    width: 30px;
    height: 30px;
    background: transparent;
    border: 1px solid var(--color-line);
    color: var(--color-fg-dim);
    cursor: pointer;
    transition:
      color 160ms var(--ease-out-expo),
      border-color 160ms var(--ease-out-expo);
  }
  .cal-nav button svg {
    width: 14px;
    height: 14px;
  }
  .cal-nav button:hover {
    color: var(--color-fg);
    border-color: var(--color-fg-faint);
  }

  .day-strip {
    overflow-x: auto;
    border: 1px solid var(--color-line-soft);
    scroll-snap-type: x proximity;
  }
  .day-track {
    position: relative;
    display: flex;
    min-width: max-content;
  }

  /* плавающая подложка выделения */
  .day-ind {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    width: 0;
    background: var(--color-accent);
    z-index: 0;
    opacity: 0;
    will-change: transform, width;
  }

  .day-track :global(.day) {
    position: relative;
    z-index: 1;
    flex: 0 0 auto;
    width: 68px;
    padding: 0.9rem 0;
    display: grid;
    gap: 0.3rem;
    justify-items: center;
    background: transparent;
    border: 0;
    border-right: 1px solid var(--color-line-soft);
    color: var(--color-fg-dim);
    cursor: pointer;
    scroll-snap-align: start;
    transition: color 220ms var(--ease-out-expo);
  }
  .day-track :global(.day:hover:not(:disabled):not(.is-active)) {
    color: var(--color-fg);
  }
  .day-track :global(.day:disabled) {
    color: var(--color-ink-600);
    cursor: not-allowed;
  }
  .day-track :global(.day.is-active) {
    color: var(--color-accent-ink);
  }
  .day-track :global(.day__wd) {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.75;
  }
  .day-track :global(.day__n) {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-sm);
  }
  /* сегодняшний день помечен точкой */
  .day-track :global(.day.is-today .day__wd::after) {
    content: "";
    display: block;
    width: 3px;
    height: 3px;
    margin: 3px auto 0;
    background: currentColor;
  }

  /* ── слоты ── */
  .slots {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .slot {
    padding: 0.75rem 1.05rem;
    background: var(--color-ink-900);
    border: 1px solid var(--color-line);
    color: var(--color-fg-dim);
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    letter-spacing: 0.04em;
    cursor: pointer;
    transition:
      background 160ms var(--ease-out-expo),
      color 160ms var(--ease-out-expo),
      border-color 160ms var(--ease-out-expo);
  }
  .slot:hover {
    color: var(--color-fg);
    border-color: var(--color-fg-faint);
  }
  .slot.is-active {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: var(--color-accent-ink);
  }

  .summary {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1.25rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-line-soft);
  }
  .summary > div {
    display: grid;
    gap: 0.4rem;
    min-width: 0;
  }
  .sum-value {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-sm);
    color: var(--color-fg-faint);
  }
  .sum-value[data-state="partial"] {
    color: var(--color-fg-dim);
  }
  .sum-value[data-state="filled"] {
    color: var(--color-fg);
  }

  @media (min-width: 1000px) {
    .grid {
      grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    }
  }
</style>
