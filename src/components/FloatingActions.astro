---
/**
 * Плавающие кнопки, вжатые в углы окна — и сбоку, и снизу.
 * Слева чат: при открытии панели иконка на том же месте превращается
 * в крестик, при закрытии — обратно.
 * Справа звонок, под ним снизу выдвигается стрелка «наверх» и приподнимает его.
 */
---

<!-- левый нижний угол: чат -->
<button
  type="button"
  class="fab fab-chat"
  id="fabChat"
  aria-label="Открыть чат"
  aria-expanded="false"
  aria-controls="chatPanel"
>
  <span class="pulse" aria-hidden="true"></span>

  <span class="ic ic-chat" aria-hidden="true">
    <svg viewBox="0 0 24 24" fill="none">
      <path
        d="M4 5.5h16v11H9.5L5.5 20v-3.5H4z"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linejoin="round"></path>
      <path d="M8 10h8M8 13h5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path>
    </svg>
  </span>

  <!-- крестик рождается ровно на месте иконки чата -->
  <span class="ic ic-close" aria-hidden="true">
    <svg viewBox="0 0 24 24" fill="none">
      <path d="M6.5 6.5l11 11M17.5 6.5l-11 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path>
    </svg>
  </span>
</button>

<!-- правый нижний угол: звонок + выдвижная стрелка -->
<div class="fab-stack" id="fabStack">
  <a href="#booking" class="fab fab-call" aria-label="Позвонить в клинику">
    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path
        d="M6.5 4h3l1.5 4-2 1.2a11 11 0 0 0 5.8 5.8L16 13l4 1.5v3a2 2 0 0 1-2.2 2A15.5 15.5 0 0 1 4.5 6.2 2 2 0 0 1 6.5 4z"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linejoin="round"></path>
    </svg>
  </a>

  <button type="button" class="fab fab-top" id="fabTop" aria-label="Наверх" tabindex="-1">
    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path
        d="M12 19V5M12 5l-6 6M12 5l6 6"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"></path>
    </svg>
  </button>
</div>

<style>
  .fab {
    --fab: 64px;
    position: relative;
    display: grid;
    place-items: center;
    width: var(--fab);
    height: var(--fab);
    background: var(--color-ink-950);
    /* мятная рамка и мятная иконка: на тёмном подвале тусклая серая кнопка
       просто пропадала */
    border: 1px solid var(--color-accent-strong);
    color: var(--color-accent);
    cursor: pointer;
    transition:
      background 260ms var(--ease-out-expo),
      color 260ms var(--ease-out-expo),
      border-color 260ms var(--ease-out-expo);
  }
  .fab svg {
    width: 24px;
    height: 24px;
  }
  .fab:hover {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: var(--color-accent-ink);
  }

  /* ── чат: вжат в левый нижний угол ── */
  .fab-chat {
    position: fixed;
    left: 0;
    bottom: 0;
    /* выше панели: кнопка остаётся на месте и становится крестиком */
    z-index: 85;
    border-left: 0;
    border-bottom: 0;
  }

  /* две иконки в одной точке: чат уходит поворотом, крестик приходит */
  .ic {
    position: absolute;
    display: grid;
    place-items: center;
    inset: 0;
    transition:
      opacity 300ms var(--ease-out-expo),
      transform 420ms var(--ease-out-expo);
  }
  .ic-chat {
    opacity: 1;
    transform: rotate(0deg) scale(1);
  }
  .ic-close {
    opacity: 0;
    transform: rotate(-90deg) scale(0.55);
  }
  .fab-chat[aria-expanded="true"] .ic-chat {
    opacity: 0;
    transform: rotate(90deg) scale(0.55);
  }
  .fab-chat[aria-expanded="true"] .ic-close {
    opacity: 1;
    transform: rotate(0deg) scale(1);
  }

  /* ── звонок + стрелка: вжаты в правый нижний угол ── */
  .fab-stack {
    position: fixed;
    right: 0;
    bottom: 0;
    z-index: 60;
    display: flex;
    flex-direction: column;
  }
  .fab-stack .fab {
    border-right: 0;
  }
  .fab-stack .fab:last-child {
    border-bottom: 0;
  }
  /* стрелка лежит под звонком: вырастая, приподнимает его */
  .fab-top {
    height: 0;
    border-top: 0;
    overflow: hidden;
    opacity: 0;
    pointer-events: none;
  }
  .fab-stack.is-up .fab-top {
    pointer-events: auto;
  }

  /* лёгкая пульсация рамкой — без свечения и градиентов */
  .pulse {
    position: absolute;
    inset: -1px;
    border: 1px solid var(--color-accent);
    opacity: 0;
    pointer-events: none;
  }
  .fab-chat[aria-expanded="true"] .pulse {
    display: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .pulse {
      display: none;
    }
    .fab-top {
      height: 64px;
      opacity: 1;
      pointer-events: auto;
    }
  }

  @media (max-width: 480px) {
    .fab {
      --fab: 58px;
    }
    .fab svg {
      width: 22px;
      height: 22px;
    }
  }
</style>
