---
import Logo from "./Logo.astro";
import Socials from "./Socials.astro";
import { brand, nav, services, PLACEHOLDER } from "../data/site";

/** Пустые контакты не рендерим — прочерки на витрине выглядят как брак. */
const has = (v: string) => v && v !== PLACEHOLDER;
---

<!-- ── Большая CTA-строка вместо дежурного блока ── -->
<section class="cta" id="contacts">
  <a href="#booking" class="cta-link" aria-label="Записаться на приём">
    <div class="wrap cta-wrap">
      <span class="eyebrow">Запись</span>
      <h2 class="display cta-title" data-split>Готовы начать лечение?</h2>
      <span class="cta-mark" aria-hidden="true">
        <svg viewBox="0 0 16 16" fill="none">
          <path d="M4 12L12 4M12 4H6M12 4V10" stroke="currentColor" stroke-width="1.2"></path>
        </svg>
      </span>
    </div>
  </a>
</section>

<footer class="footer">
  <div class="wrap">
    <div class="f-top">
      <div class="f-col f-brand">
        <Logo variant="lockup" />
        <p class="f-tag">{brand.tagline}</p>
        <Socials />
      </div>

      <nav class="f-col" aria-label="Разделы">
        <span class="f-h">Разделы</span>
        {nav.map((n) => <a href={n.href} class="f-link">{n.label}</a>)}
      </nav>

      <nav class="f-col" aria-label="Услуги">
        <span class="f-h">Услуги</span>
        {services.slice(0, 5).map((s) => <a href="#services" class="f-link">{s.title}</a>)}
      </nav>

      <div class="f-col">
        <span class="f-h">Контакты</span>
        {has(brand.phone) && <a href={`tel:${brand.phone}`} class="f-link tnum">{brand.phone}</a>}
        {has(brand.email) && <a href={`mailto:${brand.email}`} class="f-link">{brand.email}</a>}
        {has(brand.address) && <span class="f-val">{brand.address}</span>}
        {has(brand.hours) && <span class="f-val tnum">{brand.hours}</span>}
        {!has(brand.phone) && !has(brand.address) && (
          <>
            <a href="#booking" class="f-link">Онлайн-запись</a>
            <a href="#faq" class="f-link">Частые вопросы</a>
            <a href="#doctors" class="f-link">Выбрать врача</a>
          </>
        )}
      </div>
    </div>

    <!-- Подпись во всю ширину. Засвечивается по мере доскролла до самого низа.
         filter и clip-path разнесены по разным слоям: иначе clip-path режет
         ореол свечения и вокруг надписи появляется прямоугольная кромка. -->
    <div class="f-wordmark" id="fWordmark" aria-hidden="true">
      <span class="f-word-base"><Logo variant="wordmark" /></span>
      <span class="f-word-glow">
        <span class="f-word-lit" id="fWordLit"><Logo variant="wordmark" /></span>
      </span>
    </div>

    <div class="f-bottom">
      <span>© <span id="year" class="tnum">2026</span> {brand.name}</span>
      <span>{brand.tagline}</span>
    </div>
  </div>
</footer>

<style>
  .wrap {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: 0 var(--gutter);
  }

  /* ── CTA ── */
  .cta {
    border-top: 1px solid var(--color-line-soft);
    background: var(--color-ink-900);
  }
  .cta-link {
    display: block;
    position: relative;
    padding: clamp(2.75rem, 6vw, 6rem) 0;
    color: var(--color-fg);
    overflow: hidden;
  }
  /* заливка приходит снизу — реагирует вся полоса, а не кнопка */
  .cta-link::before {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--color-accent);
    transform: translateY(101%);
    transition: transform 620ms var(--ease-out-expo);
  }
  .cta-link:hover::before {
    transform: translateY(0);
  }
  .cta-link:hover {
    color: var(--color-accent-ink);
  }
  .cta-link:hover .eyebrow {
    color: color-mix(in oklch, var(--color-accent-ink) 70%, transparent);
  }
  .cta-link:hover .eyebrow::before {
    background: var(--color-accent-ink);
  }

  .cta-wrap {
    position: relative;
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: end;
    gap: 1.5rem;
  }
  .cta-wrap .eyebrow {
    grid-column: 1 / -1;
    margin-bottom: 1.25rem;
  }
  .cta-title {
    font-size: clamp(2.2rem, 7vw, 7rem);
    margin: 0;
  }
  .cta-mark {
    display: grid;
    place-items: center;
    width: clamp(48px, 5vw, 84px);
    aspect-ratio: 1;
    border: 1px solid currentColor;
    flex: none;
  }
  .cta-mark svg {
    width: 42%;
    height: 42%;
    transition: transform 420ms var(--ease-out-expo);
  }
  .cta-link:hover .cta-mark svg {
    transform: translate(3px, -3px);
  }

  /* ── Подвал ── */
  .footer {
    background: var(--color-ink-950);
    border-top: 1px solid var(--color-line-soft);
    padding: clamp(2rem, 4vw, 3.25rem) 0 1.5rem;
  }

  /* колонки живут в общей сетке с 1px разделителями — та же пластика,
     что у панелей и услуг. Иначе «столбы» висят в воздухе вразнобой. */
  .f-top {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1px;
    background: var(--color-line-soft);
    border: 1px solid var(--color-line-soft);
  }

  .f-col {
    display: grid;
    gap: 0.5rem;
    align-content: start;
    min-width: 0;
    background: var(--color-ink-950);
    padding: clamp(1.1rem, 2vw, 1.6rem);
  }
  .f-brand {
    grid-column: 1 / -1;
    gap: 1rem;
    justify-items: start;
    color: var(--color-fg);
  }
  /* на две колонки приходится три группы — последняя занимает ряд целиком,
     иначе в сетке зияет пустая ячейка */
  .f-top > .f-col:last-child {
    grid-column: 1 / -1;
  }
  .f-tag {
    margin: 0;
    font-size: var(--text-2xs);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--color-fg-faint);
  }

  .f-h {
    font-size: var(--text-2xs);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--color-fg-faint);
    margin-bottom: 0.15rem;
  }

  .f-link,
  .f-val {
    font-size: var(--text-xs);
    line-height: 1.9;
    color: var(--color-fg-dim);
    width: fit-content;
  }
  .f-link {
    position: relative;
    transition: color 180ms var(--ease-out-expo);
  }
  .f-link::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -2px;
    width: 100%;
    height: 1px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: right center;
    transition: transform 320ms var(--ease-out-expo);
  }
  .f-link:hover {
    color: var(--color-fg);
  }
  .f-link:hover::after {
    transform: scaleX(1);
    transform-origin: left center;
  }

  /* подпись клиники: крупная, но не во всю ширину — иначе давит подвал */
  .f-wordmark {
    position: relative;
    width: clamp(240px, 46%, 640px);
    margin: clamp(1.75rem, 3.5vw, 3rem) 0 clamp(1rem, 2vw, 1.5rem);
    line-height: 0;
  }
  /* Базовый слой — контур, а не заливка: пустые буквы «вывески» цепляют глаз
     сами по себе, а свет потом наливает их изнутри. */
  .f-word-base {
    display: block;
    color: var(--color-ink-600);
  }
  .f-word-base :global(path) {
    fill: none;
    stroke: currentColor;
    stroke-width: 1.1;
    vector-effect: non-scaling-stroke;
  }
  /* внешний слой держит свечение, внутренний — маску заливки */
  .f-word-glow {
    position: absolute;
    inset: 0;
    display: block;
    transition: filter 420ms var(--ease-out-expo);
  }
  .f-wordmark.is-lit .f-word-glow {
    filter:
      drop-shadow(0 0 10px color-mix(in oklch, var(--color-paper) 55%, transparent))
      drop-shadow(0 0 34px color-mix(in oklch, var(--color-paper) 30%, transparent));
  }
  .f-word-lit {
    display: block;
    color: var(--color-paper);
    clip-path: inset(0 100% 0 0);
    will-change: clip-path;
  }

  /* перебиваем фиксированную высоту из Logo.astro */
  .f-wordmark :global(.logo-word) {
    display: block;
    height: auto;
    width: 100%;
  }
  .f-wordmark :global(.logo-word svg) {
    width: 100%;
    height: auto;
  }

  /* Нижняя строка: вместо гигантского отступа снизу просто уводим текст
     из-под плавающих кнопок по горизонтали — они прижаты к углам. */
  .f-bottom {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem 1.5rem;
    margin-inline: 72px;
    padding-top: 1rem;
    border-top: 1px solid var(--color-line-soft);
    font-size: var(--text-2xs);
    letter-spacing: 0.06em;
    color: var(--color-fg-faint);
  }
  @media (max-width: 560px) {
    .f-bottom {
      margin-inline: 66px;
      justify-content: center;
      text-align: center;
    }
  }

  @media (min-width: 720px) {
    .f-top {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
    .f-top > .f-col:last-child {
      grid-column: auto;
    }
  }
  @media (min-width: 1080px) {
    .f-top {
      grid-template-columns: 1.6fr repeat(3, minmax(0, 1fr));
    }
    .f-brand {
      grid-column: auto;
    }
  }
</style>
