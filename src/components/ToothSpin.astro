---
/** Фото прозрачной модели челюсти + дуга осмотра 360° (как в референсе). */
---

<div class="scene" data-spin-scope>
  <div class="stage" data-parallax="5">
    <img
      src="/img/aligners.webp"
      alt="Прозрачная модель челюсти"
      width="1100"
      height="940"
      loading="lazy"
      decoding="async"
    />
  </div>

  <svg class="arc" viewBox="0 0 260 80" fill="none" aria-hidden="true">
    <path
      d="M8 12 C8 56 60 74 130 74 C200 74 252 56 252 12"
      stroke="currentColor"
      stroke-width="1.2"
      opacity="0.6"
      data-draw
    />
    <rect x="4" y="8" width="8" height="8" fill="currentColor" />
    <rect x="248" y="8" width="8" height="8" fill="currentColor" />
  </svg>

  <span class="readout tnum" data-spin-readout>0°</span>
</div>

<style>
  .scene {
    position: relative;
    display: grid;
    place-items: center;
    padding: 1.5rem 0 3.25rem;
  }

  .stage {
    will-change: transform;
  }
  .scene img {
    display: block;
    width: min(100%, 320px);
    height: auto;
    filter: drop-shadow(0 22px 38px oklch(0 0 0 / 0.5));
  }

  .arc {
    position: absolute;
    bottom: 1.6rem;
    width: min(78%, 260px);
    color: var(--color-accent);
    pointer-events: none;
  }

  .readout {
    position: absolute;
    bottom: 0;
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.06em;
    color: var(--color-fg);
  }
</style>
