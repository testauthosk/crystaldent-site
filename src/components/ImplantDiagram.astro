---
/**
 * Фото анатомической модели импланта + выноски.
 * Координаты в % кадра. Параллакс живёт на .stage, иначе картинка
 * уезжает от собственных выносок.
 */
const callouts = [
  { label: "Керамическая коронка", from: [45, 17], to: [92, 7], side: "r" },
  { label: "Титановый имплант", from: [44, 56], to: [6, 45], side: "l" },
  { label: "Костная ткань", from: [73, 66], to: [94, 83], side: "r" },
];
---

<div class="shot" data-spin-scope>
  <div class="stage" data-parallax="5">
    <img
      src="/img/implant.webp"
      alt="Анатомическая модель зубного импланта в разрезе"
      width="660"
      height="645"
      loading="lazy"
      decoding="async"
    />

    <svg
      class="lines"
      viewBox="0 0 100 100"
      preserveAspectRatio="none"
      width="100%"
      height="100%"
      fill="none"
      aria-hidden="true"
    >
      {
        callouts.map((c) => (
          <path
            d={`M${c.from[0]} ${c.from[1]} L${c.to[0]} ${c.to[1]}`}
            stroke="var(--color-accent)"
            stroke-width="1.4"
            vector-effect="non-scaling-stroke"
            opacity="0.85"
            data-draw
          />
        ))
      }
      {
        callouts.map((c) => (
          <rect x={c.from[0] - 0.9} y={c.from[1] - 0.9} width="1.8" height="1.8" fill="var(--color-accent)" />
        ))
      }
    </svg>

    {
      callouts.map((c) => (
        <span
          class:list={["tag", c.side === "r" ? "tag--r" : "tag--l"]}
          style={`top:${c.to[1]}%; ${c.side === "r" ? `left:calc(${c.to[0]}% + 9px)` : `right:calc(${100 - c.to[0]}% + 9px)`}`}
        >
          {c.label}
        </span>
      ))
    }
  </div>
</div>

<style>
  .shot {
    width: 100%;
    max-width: 520px;
    margin-inline: auto;
    padding-inline: clamp(48px, 13%, 74px);
    padding-block: 1.75rem 2.25rem;
  }

  .stage {
    position: relative;
    will-change: transform;
  }

  .stage img {
    display: block;
    width: 100%;
    height: auto;
    filter: drop-shadow(0 24px 40px oklch(0 0 0 / 0.55));
  }

  .lines {
    position: absolute;
    inset: 0;
    overflow: visible;
    pointer-events: none;
  }

  .tag {
    position: absolute;
    transform: translateY(-50%);
    font-size: var(--text-2xs);
    line-height: 1.3;
    letter-spacing: 0.04em;
    color: var(--color-fg-dim);
    width: clamp(56px, 16vw, 84px);
  }
  .tag--l {
    text-align: right;
  }

  @media (max-width: 640px) {
    .tag {
      font-size: 10px;
    }
  }
</style>
