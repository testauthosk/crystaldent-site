---
import { doctors } from "../data/site";
---

<section class="sec" id="doctors">
  <div class="wrap">
    <header class="doc-head">
      <div>
        <span class="eyebrow reveal">Команда</span>
        <h2 class="display sec-title" data-split>Врачи клиники</h2>
      </div>
      <p class="lede reveal">
        Профиль каждого специалиста, свободные окна в расписании и запись в два клика — без звонков
        и ожидания на линии.
      </p>
    </header>

    <div class="docs">
      {
        doctors.map((d) => (
          <article class="doc group reveal">
            <div class="doc-photo" data-img-reveal>
              <img
                src={d.photo}
                alt={`${d.role} клиники CrystalDent`}
                width="720"
                height="900"
                loading="lazy"
                decoding="async"
              />
              <span class="doc-veil" aria-hidden="true" />
            </div>

            <div class="doc-body">
              <div class="doc-top">
                <h3 class="doc-name">{d.name}</h3>
                <span class="arrow-box">
                  <svg viewBox="0 0 16 16" fill="none">
                    <path d="M4 12L12 4M12 4H6M12 4V10" stroke="currentColor" stroke-width="1.4" />
                  </svg>
                </span>
              </div>

              <span class="doc-role">{d.role}</span>
              <p class="doc-focus">{d.focus}</p>

              <a href="#booking" class="doc-cta">
                Выбрать время
                <svg viewBox="0 0 16 16" fill="none">
                  <path d="M4 12L12 4M12 4H6M12 4V10" stroke="currentColor" stroke-width="1.4"></path>
                </svg>
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .sec {
    padding: var(--sec-y) 0;
    background: var(--color-ink-950);
    border-bottom: 1px solid var(--color-line-soft);
  }
  .wrap {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: 0 var(--gutter);
  }

  .doc-head {
    display: grid;
    gap: 1.75rem;
    margin-bottom: clamp(3rem, 6vw, 5.5rem);
  }
  .doc-head .eyebrow {
    margin-bottom: 1.5rem;
  }

  .docs {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    background: var(--color-line-soft);
    border: 1px solid var(--color-line-soft);
  }

  .doc {
    background: var(--color-ink-900);
    padding: clamp(1.25rem, 1.8vw, 1.75rem);
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    transition: background 220ms var(--ease-out-expo);
  }
  .doc:hover {
    background: var(--color-ink-850);
  }

  .doc-photo {
    position: relative;
    aspect-ratio: 4 / 5;
    background: var(--color-ink-800);
    border: 1px solid var(--color-line-soft);
    overflow: hidden;
  }
  .doc-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 600ms var(--ease-out-expo);
  }
  .doc:hover .doc-photo img {
    transform: scale(1.04);
  }
  .doc-veil {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, color-mix(in oklch, var(--color-ink-950) 55%, transparent), transparent 45%);
    pointer-events: none;
  }

  .doc-body {
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .doc-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }
  .doc-name {
    font-family: var(--font-display);
    font-weight: 700;
    text-transform: uppercase;
    font-size: var(--text-sm);
    letter-spacing: 0.03em;
    margin: 0;
  }
  .doc-role {
    margin-top: 0.35rem;
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
  }
  .doc-focus {
    margin: 0.75rem 0 0;
    font-size: var(--text-sm);
    color: var(--color-fg-dim);
  }

  .doc-meta {
    margin-top: 1rem;
    padding-top: 0.9rem;
    border-top: 1px solid var(--color-line-soft);
  }
  .doc-exp {
    font-size: var(--text-xs);
    color: var(--color-fg-faint);
  }

  .doc-cta {
    margin-top: 1.25rem;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--text-2xs);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-fg-dim);
    transition: color 160ms var(--ease-out-expo);
  }
  .doc-cta svg {
    width: 13px;
    height: 13px;
    transition: transform 220ms var(--ease-out-expo);
  }
  .doc:hover .doc-cta {
    color: var(--color-fg);
  }
  .doc:hover .doc-cta svg {
    transform: translate(2px, -2px);
  }

  .todo {
    margin: 1.5rem 0 0;
    font-size: var(--text-2xs);
    letter-spacing: 0.06em;
    color: var(--color-fg-faint);
  }

  @media (min-width: 640px) {
    .docs {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1080px) {
    .docs {
      grid-template-columns: repeat(4, 1fr);
    }
    .doc-head {
      grid-template-columns: 1.35fr 0.65fr;
      align-items: end;
      gap: 4rem;
    }
  }
</style>
