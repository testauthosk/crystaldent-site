---
/**
 * Прелоадер: белая подложка, поверх — сетка чёрных кубиков с белой окантовкой.
 * Волна схлопывает кубики от четырёх углов к центру. Никаких градиентов и
 * подсветок: кубик либо есть, либо его нет.
 *
 * Знак лежит ПОД сеткой — по мере очистки центра он проявляется сам, остаётся
 * один на белом, затем исчезает и подложка уходит вверх.
 */
---

<div id="preloader" aria-hidden="true">
  <div id="preMark" class="pre-mark"></div>
  <div id="preTiles" class="tiles"></div>
</div>

<script is:inline>
  // Строим сетку синхронно, до первой отрисовки: если ждать модуль motion.ts,
  // экран успевает моргнуть белым.
  (() => {
    if (matchMedia("(prefers-reduced-motion: reduce)").matches) return;
    const grid = document.getElementById("preTiles");
    if (!grid) return;

    const vw = window.innerWidth;
    const tile = vw >= 1024 ? 68 : vw >= 640 ? 48 : 32; // на компе крупнее, на мобиле мельче
    const cols = Math.ceil(vw / tile);
    const rows = Math.ceil(window.innerHeight / tile);

    grid.style.gridTemplateColumns = `repeat(${cols}, 1fr)`;
    grid.style.gridTemplateRows = `repeat(${rows}, 1fr)`;
    grid.dataset.cols = String(cols);
    grid.dataset.rows = String(rows);

    const frag = document.createDocumentFragment();
    for (let i = 0; i < rows * cols; i++) {
      const d = document.createElement("div");
      d.className = "tile";
      frag.appendChild(d);
    }
    grid.appendChild(frag);
  })();
</script>

<style>
  #preloader {
    position: fixed;
    inset: 0;
    z-index: 100;
    pointer-events: none;
    background: var(--color-paper);
  }
  html:not(.js) #preloader {
    display: none;
  }

  .tiles {
    position: absolute;
    inset: 0;
    z-index: 1;
    display: grid;
  }

  .tiles :global(.tile) {
    box-sizing: border-box;
    background: #0b1116;
    border: 1px solid var(--color-paper);
    will-change: transform;
  }

  /* знак под сеткой: остаётся один, когда кубики в центре схлопнутся */
  .pre-mark {
    position: absolute;
    z-index: 0;
    top: 50%;
    left: 50%;
    width: clamp(54px, 7vw, 98px);
    aspect-ratio: 124 / 152;
    transform: translate(-50%, -50%);
    background: #0b1116;
    -webkit-mask: url("/brand/mark.svg") center / contain no-repeat;
    mask: url("/brand/mark.svg") center / contain no-repeat;
    will-change: transform, opacity;
  }

  @media (prefers-reduced-motion: reduce) {
    #preloader {
      display: none;
    }
  }
</style>
