---
import markSvg from "../brand/mark.svg?raw";

/**
 * Прелоадер-метафора: чёрные зубы становятся белыми.
 *
 * Старт — чёрный экран. Волна идёт от четырёх углов к центру: фронт вспыхивает
 * белой окантовкой, кубик схлопывается, за ним остаётся белое.
 * Последний островок черноты — знак-зуб. Он отбеливается снизу вверх, но НЕ
 * растворяется: у белого слоя есть тёмный контур, поэтому зуб остаётся
 * читаемым. Затем подложка уходит вверх.
 *
 * Никаких градиентов: у кубика два состояния — чёрный и белый.
 */
---

<div id="preloader" aria-hidden="true">
  <div class="pre-mark" id="preMark">
    <span class="mark-dark" set:html={markSvg} />
    <span class="mark-lit" id="preMarkLit" set:html={markSvg} />
  </div>
  <div id="preTiles" class="tiles"></div>
</div>

<script is:inline>
  // Сетку строим синхронно, до первой отрисовки: если ждать модуль motion.ts,
  // экран успевает моргнуть белым.
  (() => {
    if (matchMedia("(prefers-reduced-motion: reduce)").matches) return;
    const grid = document.getElementById("preTiles");
    if (!grid) return;

    const vw = window.innerWidth;
    const tile = vw >= 1024 ? 68 : vw >= 640 ? 48 : 32; // на компе крупнее, на мобиле мельче
    const cols = Math.ceil(vw / tile);
    const rows = Math.ceil(window.innerHeight / tile);

    grid.style.gridTemplateColumns = `repeat(${cols}, 1fr)`;
    grid.style.gridTemplateRows = `repeat(${rows}, 1fr)`;
    grid.dataset.cols = String(cols);
    grid.dataset.rows = String(rows);

    const frag = document.createDocumentFragment();
    for (let i = 0; i < rows * cols; i++) {
      const d = document.createElement("div");
      d.className = "tile";
      frag.appendChild(d);
    }
    grid.appendChild(frag);
  })();
</script>

<style>
  #preloader {
    position: fixed;
    inset: 0;
    z-index: 100;
    pointer-events: none;
    background: var(--color-paper);
  }
  html:not(.js) #preloader {
    display: none;
  }

  .tiles {
    position: absolute;
    inset: 0;
    z-index: 1;
    display: grid;
  }

  /* в покое экран читается чёрным: окантовка едва темнее заливки.
     белой она вспыхивает только на гребне волны */
  .tiles :global(.tile) {
    box-sizing: border-box;
    background: #0b1116;
    border: 1px solid #16212a;
    will-change: transform, border-color;
  }

  /* знак под сеткой: последний островок черноты */
  .pre-mark {
    position: absolute;
    z-index: 0;
    top: 50%;
    left: 50%;
    width: clamp(54px, 7vw, 98px);
    aspect-ratio: 124 / 152;
    transform: translate(-50%, -50%);
  }
  .pre-mark span {
    position: absolute;
    inset: 0;
    display: block;
  }
  .pre-mark :global(svg) {
    width: 100%;
    height: 100%;
    display: block;
    overflow: visible;
  }

  .mark-dark :global(path) {
    fill: #0b1116;
  }

  /* белый слой: «отбеливание» идёт снизу вверх.
     контур обязателен — без него белый зуб пропадает на белом экране */
  .mark-lit {
    clip-path: inset(100% 0 0 0);
    will-change: clip-path;
  }
  .mark-lit :global(path) {
    fill: var(--color-paper);
    stroke: #0b1116;
    stroke-width: 2;
    vector-effect: non-scaling-stroke;
  }

  @media (prefers-reduced-motion: reduce) {
    #preloader {
      display: none;
    }
  }
</style>
