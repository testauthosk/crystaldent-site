---
import { slots } from "../data/site";

const weekdays = ["Пн", "Вт", "Ср", "Чт", "Пт", "Сб", "Вс"];
---

<div id="calBackdrop" aria-hidden="true"></div>

<div id="calModal" role="dialog" aria-modal="true" aria-labelledby="cmTitle" aria-hidden="true">
  <div class="cm-inner">
    <header class="cm-head">
      <div>
        <span class="eyebrow">Онлайн-запись</span>
        <h3 class="cm-title display" id="cmTitle">Выберите дату и время</h3>
      </div>
      <button type="button" id="cmClose" aria-label="Закрыть календарь">
        <svg viewBox="0 0 24 24" fill="none">
          <path d="M6.5 6.5l11 11M17.5 6.5l-11 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path>
        </svg>
      </button>
    </header>

    <div class="cm-month">
      <button type="button" id="cmPrev" aria-label="Предыдущий месяц">
        <svg viewBox="0 0 16 16" fill="none"><path d="M10 3L5 8l5 5" stroke="currentColor" stroke-width="1.4"/></svg>
      </button>
      <span class="cm-month-label tnum" id="cmMonth"></span>
      <button type="button" id="cmNext" aria-label="Следующий месяц">
        <svg viewBox="0 0 16 16" fill="none"><path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="1.4"/></svg>
      </button>
    </div>

    <div class="cm-week" aria-hidden="true">
      {weekdays.map((w) => <span>{w}</span>)}
    </div>

    <div class="cm-grid" id="cmGrid">
      <!-- подложка выделения плавает между числами -->
      <span class="float-ind" id="cmDayInd" aria-hidden="true"></span>
    </div>

    <div class="cm-times">
      <span class="cm-label">Время</span>
      <div class="cm-slots" id="cmSlots">
        <span class="float-ind" id="cmSlotInd" aria-hidden="true"></span>
        {
          slots.map((t) => (
            <button type="button" class="cm-slot tnum" data-slot={t}>
              {t}
            </button>
          ))
        }
      </div>
    </div>

    <footer class="cm-foot">
      <div>
        <span class="cm-label">Ваш визит</span>
        <span class="cm-summary tnum" id="cmSummary">Выберите дату и время</span>
      </div>
      <button type="button" class="btn" id="cmApply" disabled>
        <span class="btn__label">Применить</span>
      </button>
    </footer>
  </div>
</div>

<style>
  #calBackdrop {
    position: fixed;
    inset: 0;
    z-index: 90;
    background: color-mix(in oklch, var(--color-ink-950) 74%, transparent);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 420ms var(--ease-out-expo);
  }
  #calBackdrop.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  /* окно парит по центру, не прилипая к краям */
  #calModal {
    position: fixed;
    top: 50%;
    left: 50%;
    z-index: 95;
    width: min(660px, calc(100vw - 2 * var(--gutter)));
    max-height: min(88svh, 900px);
    overflow-y: auto;
    transform: translate(-50%, -46%);
    background: var(--color-ink-950);
    border: 1px solid var(--color-line);
    opacity: 0;
    pointer-events: none;
    clip-path: inset(6% 0 6% 0);
    transition:
      opacity 320ms var(--ease-out-expo),
      transform 520ms var(--ease-out-expo),
      clip-path 520ms var(--ease-out-expo);
  }
  #calModal.is-open {
    opacity: 1;
    pointer-events: auto;
    transform: translate(-50%, -50%);
    clip-path: inset(0 0 0 0);
  }

  .cm-inner {
    padding: clamp(1.25rem, 2.4vw, 2rem);
    display: grid;
    gap: 1.5rem;
  }

  .cm-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1.5rem;
  }
  .cm-title {
    margin: 0.75rem 0 0;
    font-size: clamp(1.1rem, 2vw, 1.6rem);
  }
  #cmClose {
    display: grid;
    place-items: center;
    width: 40px;
    height: 40px;
    flex: none;
    background: transparent;
    border: 1px solid var(--color-line);
    color: var(--color-fg-dim);
    cursor: pointer;
    transition:
      color 180ms var(--ease-out-expo),
      border-color 180ms var(--ease-out-expo);
  }
  #cmClose svg {
    width: 17px;
    height: 17px;
  }
  #cmClose:hover {
    color: var(--color-fg);
    border-color: var(--color-fg-faint);
  }

  .cm-month {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-line-soft);
  }
  .cm-month-label {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .cm-month button {
    display: grid;
    place-items: center;
    width: 34px;
    height: 34px;
    background: transparent;
    border: 1px solid var(--color-line);
    color: var(--color-fg-dim);
    cursor: pointer;
    transition:
      color 180ms var(--ease-out-expo),
      border-color 180ms var(--ease-out-expo);
  }
  .cm-month button svg {
    width: 15px;
    height: 15px;
  }
  .cm-month button:hover:not(:disabled) {
    color: var(--color-fg);
    border-color: var(--color-fg-faint);
  }
  .cm-month button:disabled {
    color: var(--color-ink-600);
    cursor: not-allowed;
  }

  .cm-week {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 1px;
    font-size: var(--text-2xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-fg-faint);
  }
  .cm-week span {
    text-align: center;
    padding-bottom: 0.35rem;
  }

  /* ячейки прозрачные с hairline-границами — плавающая подложка видна сквозь
     них; непрозрачная заливка её бы скрыла */
  .cm-grid {
    position: relative;
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    border: 1px solid var(--color-line-soft);
    background: var(--color-ink-950);
  }

  /* общая подложка выделения: плавает между ячейками */
  .float-ind {
    position: absolute;
    top: 0;
    left: 0;
    width: 0;
    height: 0;
    background: var(--color-accent);
    z-index: 0;
    opacity: 0;
    pointer-events: none;
    will-change: transform, width, height;
  }

  .cm-grid :global(.cm-day) {
    position: relative;
    z-index: 1;
    aspect-ratio: 1;
    display: grid;
    place-items: center;
    background: transparent;
    border: 0;
    border-right: 1px solid var(--color-line-soft);
    border-bottom: 1px solid var(--color-line-soft);
    color: var(--color-fg-dim);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-xs);
    font-variant-numeric: tabular-nums;
    cursor: pointer;
    transition: color 220ms var(--ease-out-expo);
  }
  /* последний столбец и нижний ряд не дублируют внешнюю рамку */
  .cm-grid :global(.cm-day:nth-child(7n)) {
    border-right: 0;
  }
  .cm-grid :global(.cm-day:hover:not(:disabled):not(.is-active)) {
    color: var(--color-fg);
  }
  .cm-grid :global(.cm-day:disabled) {
    color: var(--color-ink-600);
    cursor: not-allowed;
  }
  .cm-grid :global(.cm-day.is-active) {
    color: var(--color-accent-ink);
  }
  .cm-grid :global(.cm-day.is-empty) {
    cursor: default;
  }
  .cm-grid :global(.cm-day.is-today::after) {
    content: "";
    position: absolute;
    bottom: 6px;
    width: 3px;
    height: 3px;
    background: currentColor;
  }

  .cm-label {
    display: block;
    font-size: var(--text-2xs);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-fg-faint);
    margin-bottom: 0.75rem;
  }

  .cm-slots {
    position: relative;
    display: flex;
    flex-wrap: wrap;
    border: 1px solid var(--color-line-soft);
    background: var(--color-ink-950);
  }
  .cm-slot {
    position: relative;
    z-index: 1;
    flex: 1 1 84px;
    padding: 0.85rem 0.5rem;
    background: transparent;
    border: 0;
    border-right: 1px solid var(--color-line-soft);
    color: var(--color-fg-dim);
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    letter-spacing: 0.04em;
    cursor: pointer;
    transition: color 220ms var(--ease-out-expo);
  }
  .cm-slot:hover:not(.is-active) {
    color: var(--color-fg);
  }
  .cm-slot.is-active {
    color: var(--color-accent-ink);
  }

  .cm-foot {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-line-soft);
  }
  .cm-summary {
    display: block;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-sm);
    color: var(--color-fg-faint);
  }
  .cm-summary[data-state="filled"] {
    color: var(--color-fg);
  }
  #cmApply:disabled {
    opacity: 0.45;
    cursor: not-allowed;
  }

  @media (prefers-reduced-motion: reduce) {
    #calModal,
    #calBackdrop {
      transition-duration: 0.01ms !important;
    }
  }
</style>
